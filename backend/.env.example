PORT=8080
JWT_SECRET=change-this-to-a-long-random-string-in-production
# Only needed if the frontend is hosted on a DIFFERENT origin than this API
# (e.g. a separate Vercel/Netlify site). If you're serving the frontend from
# this same Express app (the default in src/server.js), same-origin requests
# don't need CORS at all — this list is just a safety net.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://crmsysteminhouse-production.up.railway.app

# There is exactly ONE Super Admin in the whole system. It is bootstrapped
# once, on first server start, from these two vars — NOT created through
# public registration. Leave unset after the first successful boot (the
# bootstrap is a no-op once a Super Admin already exists), and rotate the
# password via the API afterwards rather than keeping it in this file.
SUPER_ADMIN_EMAIL=superadmin@yourcompany.com
SUPER_ADMIN_PASSWORD=change-this-immediately-min-12-chars

