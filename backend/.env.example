PORT=8080
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Only needed if the frontend is hosted on a DIFFERENT origin than this API
# (e.g. a separate Vercel/Netlify site). If you're serving the frontend from
# this same Express app (the default in src/server.js), same-origin requests
# don't need CORS at all — this list is just a safety net.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://crmsysteminhouse-production.up.railway.app

# --- Database driver ---
# Which storage backend src/db/index.js loads. Everything else in the app is
# written against the generic repository interface (src/db/index.js), so
# changing this value + implementing the matching driver in src/db/drivers/
# is the ONLY code change needed to switch databases.
#   lowdb    -> JSON file on disk (default, zero setup, good for dev/testing)
#   postgres -> needs `npm install pg` + DATABASE_URL + src/db/drivers/postgresDriver.js filled in
#   mysql    -> needs `npm install mysql2` + DATABASE_URL + src/db/drivers/mysqlDriver.js filled in
#   mongodb  -> needs `npm install mongodb` + DATABASE_URL + src/db/drivers/mongoDriver.js filled in
DB_DRIVER=lowdb

# Only used once DB_DRIVER is postgres/mysql/mongodb:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# NOTE: there are no SUPER_ADMIN_EMAIL / SUPER_ADMIN_PASSWORD variables here
# on purpose. The Super Admin account is created once, through the app itself
# (POST /api/v1/setup/super-admin, or the "System setup" screen in the
# frontend) — not seeded from environment variables. See routes/v1/setup.js.
